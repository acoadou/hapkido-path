---
import { getCollection } from 'astro:content';
import PrincipleLayout from '@layouts/PrincipleLayout.astro';
export async function getStaticPaths() {
  const entries = await getCollection('principles');
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<PrincipleLayout entry={entry}><Content /></PrincipleLayout>
