---
import ContentLayout from '@layouts/ContentLayout.astro';
import PrincipleCard from '@components/PrincipleCard.astro';
import { getCollection } from 'astro:content';
import { contentHref } from '@utils/paths';
const principles = (await getCollection('principles')).sort((a, b) => a.data.order - b.data.order);
---
<ContentLayout title="Principles" eyebrow="Mechanics" description="Reusable physical ideas that make techniques clearer, safer, and less dependent on strength." breadcrumbs={[{ label: 'Principles' }]}>
  <p class="callout">This section is scaffolded and will grow as techniques are documented. Principle pages are study notes for recurring mechanics, not replacements for in-person correction.</p>
  <div class="grid grid-2">{principles.map((principle) => <PrincipleCard principle={principle} href={contentHref('principles', principle.id)} />)}</div>
</ContentLayout>
