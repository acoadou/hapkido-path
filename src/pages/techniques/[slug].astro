---
import { getCollection } from 'astro:content';
import TechniqueLayout from '@layouts/TechniqueLayout.astro';
export async function getStaticPaths() {
  const entries = await getCollection('techniques');
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<TechniqueLayout entry={entry}><Content /></TechniqueLayout>
