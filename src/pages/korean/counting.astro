---
import { getEntry } from 'astro:content';
import ContentLayout from '@layouts/ContentLayout.astro';
const entry = await getEntry('korean', 'counting');
if (!entry) throw new Error('Missing Korean content: counting');
const { Content } = await entry.render();
---
<ContentLayout title={entry.data.title} eyebrow="Korean" description={entry.data.summary}>
  <Content />
</ContentLayout>
