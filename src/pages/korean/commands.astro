---
import { getEntry, render } from 'astro:content';
import ContentLayout from '@layouts/ContentLayout.astro';
const entry = await getEntry('korean', 'commands');
if (!entry) throw new Error('Missing Korean content: commands');
const { Content } = await render(entry);
---
<ContentLayout title={entry.data.title} eyebrow="Korean" description={entry.data.summary} breadcrumbs={[{ label: 'Korean', href: '/korean/' }, { label: entry.data.title }]}>
  <Content />
</ContentLayout>
