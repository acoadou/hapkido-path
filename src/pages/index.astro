---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import BeltPathCard from '@components/BeltPathCard.astro';
import Disclaimer from '@components/Disclaimer.astro';
import SafetyNote from '@components/SafetyNote.astro';
import { getCollection } from 'astro:content';
import { contentHref, withBase } from '@utils/paths';
const levels = (await getCollection('learn')).filter((entry) => entry.data.type === 'belt-overview').sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="The Hapkido Path">
  <Hero title="Hapkido Path" subtitle="A structured Hapkido study path for learning, reviewing, and organizing techniques." primaryHref={withBase('/curriculum/')} primaryLabel="View Curriculum" secondaryHref={withBase('/practice/')} secondaryLabel="Practice Tools" />
  <section class="section-tight"><div class="container">
    <p class="lead">This site combines a beginner learning path organized by belt-like levels, a detailed technique atlas, practical principles, practice tools, Korean vocabulary notes, and source references.</p>
    <p class="callout">The current scope covers White to Yellow and Yellow to Green only.</p>
  </div></section>
  <section class="section-tight"><div class="container grid grid-3">
    <Card title="Start learning" href={withBase('/learn/')}><p>Follow the active learning levels and lesson sequence.</p></Card>
    <Card title="Browse techniques" href={withBase('/techniques/')}><p>Use detailed technique pages for technical review.</p></Card>
    <Card title="Review principles" href={withBase('/principles/')}><p>Study recurring mechanics that connect techniques.</p></Card>
    <Card title="Practice" href={withBase('/practice/')}><p>Use drills, checklists, and flashcard structures.</p></Card>
  </div></section>
  <section class="section"><div class="container">
    <p class="eyebrow">Curriculum scope</p><h2>Start with the first two training arcs</h2>
    <p><a class="button" href={withBase('/curriculum/')}>View Curriculum</a></p>
    <div class="grid grid-2">{levels.map((level) => <BeltPathCard belt={level} href={contentHref('learn', level.id)} />)}</div>
  </div></section>
  <section class="section-tight"><div class="container grid grid-2"><SafetyNote /><Disclaimer /></div></section>
</BaseLayout>
<style>.lead { max-width: 900px; font-size: 1.2rem; }</style>
