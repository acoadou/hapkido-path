---
import { withBase } from '@utils/paths';
import ContentLayout from '@layouts/ContentLayout.astro';
---
<ContentLayout title="Solo Drills" eyebrow="Practice" description="Solo structures for movement paths, footwork, posture, and sequencing." breadcrumbs={[{ label: 'Practice', href: '/practice/' }, { label: 'Solo Drills' }]}>
  <h2>Outside Circular Motion Drill</h2>
  <h3>Purpose</h3>
  <p>Train the outside circular path used in sleeve-grab entries without applying a lock.</p>
  <h3>Movement</h3>
  <ol>
    <li>Start in a relaxed stance with one arm lightly forward.</li>
    <li>Move the arm on a large outside circle while turning the hips.</li>
    <li>Step off the line and keep the hand near centerline at the end.</li>
  </ol>
  <h3>Related techniques</h3>
  <ul><li><a href={withBase('/techniques/outside-sleeve-1/')}>Outside Sleeve 1</a></li></ul>
</ContentLayout>
