---
import ContentLayout from '@layouts/ContentLayout.astro';
import Checklist from '@components/Checklist.astro';
import { getCollection } from 'astro:content';
const levels = (await getCollection('learn')).filter((entry) => entry.data.type === 'belt-overview').sort((a, b) => a.data.order - b.data.order);
---
<ContentLayout title="Exam Checklists" eyebrow="Practice" description="Sample readiness checklists for the first two learning arcs." breadcrumbs={[{ label: 'Practice', href: '/practice/' }, { label: 'Exam Checklists' }]}>
  <div class="grid grid-2">{levels.map((level) => <Checklist title={level.data.title} items={level.data.checklist} />)}</div>
</ContentLayout>
