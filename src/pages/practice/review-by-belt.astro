---
import ContentLayout from '@layouts/ContentLayout.astro';
import BeltPathCard from '@components/BeltPathCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '@utils/paths';
const belts = (await getCollection('belts')).sort((a, b) => a.data.order - b.data.order);
---
<ContentLayout title="Review by Belt" eyebrow="Practice" description="Use belt pages as structured review plans.">
  <div class="grid grid-2">{belts.map((belt) => <BeltPathCard belt={belt} href={withBase(`/learn/${belt.data.slug}/`)} />)}</div>
</ContentLayout>
