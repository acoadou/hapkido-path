---
import ContentLayout from '@layouts/ContentLayout.astro';
import BeltPathCard from '@components/BeltPathCard.astro';
import { getCollection } from 'astro:content';
import { contentHref } from '@utils/paths';
const levels = (await getCollection('learn')).filter((entry) => entry.data.type === 'belt-overview').sort((a, b) => a.data.order - b.data.order);
---
<ContentLayout title="Review by Belt" eyebrow="Practice" description="Use active level pages as structured review plans." breadcrumbs={[{ label: 'Practice', href: '/practice/' }, { label: 'Review by Belt' }]}>
  <div class="grid grid-2">{levels.map((level) => <BeltPathCard belt={level} href={contentHref('learn', level.id)} />)}</div>
</ContentLayout>
