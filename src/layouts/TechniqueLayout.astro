---
import BaseLayout from './BaseLayout.astro';
import Tag from '@components/Tag.astro';
import SafetyNote from '@components/SafetyNote.astro';
interface Props { entry: any; }
const { entry } = Astro.props;
const data = entry.data;
---
<BaseLayout title={data.title} description={data.summary}>
  <section class="section">
    <div class="container">
      <p class="eyebrow">{data.category}</p>
      <h1>{data.title}</h1>
      <p class="muted intro">{data.summary}</p>
      <ul class="meta-list">
        <li><Tag label={data.beltLevel} /></li>
        <li><Tag label={data.attackType} /></li>
        {data.riskAreas.map((risk) => <li><Tag label={`Risk: ${risk}`} /></li>)}
      </ul>
      <div class="grid grid-2 page-grid">
        <article class="content-panel">
          <h2>Technical notes</h2>
          <p><strong>Core principle:</strong> {data.corePrinciple}</p>
          <slot />
        </article>
        <aside class="side-stack">
          <SafetyNote />
          <section class="card">
            <h2>Related principles</h2>
            <div class="tags">{data.principles.map((principle) => <Tag label={principle} />)}</div>
          </section>
          <section class="card">
            <h2>Related techniques</h2>
            <ul>{data.relatedTechniques.map((technique) => <li>{technique}</li>)}</ul>
          </section>
          <section class="placeholder">Image gallery placeholder for original photos or diagrams.</section>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
  .intro { max-width: 760px; font-size: 1.15rem; }
  .page-grid { align-items: start; grid-template-columns: minmax(0, 1.7fr) minmax(260px, 0.8fr); margin-top: 1.5rem; }
  .side-stack { display: grid; gap: 1rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  @media (max-width: 860px) { .page-grid { grid-template-columns: 1fr; } }
</style>
