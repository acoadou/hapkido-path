---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Tag from '@components/Tag.astro';
import SafetyNote from '@components/SafetyNote.astro';
import ReferenceList from '@components/ReferenceList.astro';
import ReferenceLink from '@components/ReferenceLink.astro';
import VisualSequence from '@components/VisualSequence.astro';
interface Props { entry: any; }
const { entry } = Astro.props;
const data = entry.data;
const belt = data.belt ?? data.beltLevel ?? 'Unassigned';
const attack = data.attack ?? data.attackType ?? 'Unassigned attack';
const risks = data.risks ?? data.riskAreas ?? [];
const related = data.relatedTechniques ?? [];
const categoryLabel = data.category.replace(/-/g, ' ');
const body = entry.body ?? '';
const hasSection = (headings: string[]) => headings.some((heading) => new RegExp(`^#{2,3}\\s+${heading}\\s*$`, 'im').test(body));
const showSafetyNote = !hasSection(['Safety note', 'Safety notes']);
const showReferenceStatus = !hasSection(['Reference status', 'Names and references']);
const showRelatedPrinciples = data.principles.length > 0 && !hasSection(['Related principles']);
const showRelatedTechniques = related.length > 0 && !hasSection(['Related techniques']);
const showMetadata = showSafetyNote || showReferenceStatus || showRelatedPrinciples || showRelatedTechniques;
---
<BaseLayout title={data.title} description={data.summary}>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Techniques', href: '/techniques/' }, { label: categoryLabel }, { label: data.title }]} />
      <p class="eyebrow">{categoryLabel}</p>
      <h1>{data.title}</h1>
      {data.summary && <p class="muted intro">{data.summary}</p>}
      <ul class="meta-list">
        <li><Tag label={belt} /></li>
        <li><Tag label={attack} /></li>
        {risks.map((risk) => <li><Tag label={`Risk: ${risk}`} /></li>)}
      </ul>
      {showMetadata && (
        <div class="metadata-grid" aria-label="Technique metadata">
          {showSafetyNote && <SafetyNote />}
          {showReferenceStatus && (
            <section class="card">
              <h2>Reference status</h2>
              <p><strong>School name:</strong> {data.school_name ?? data.title}</p>
              <p><strong>Tedeschi reference:</strong> {data.tedeschi_reference_name || 'TODO'}</p>
              <p><strong>Reference page:</strong> {data.tedeschi_reference_page || 'TODO'}</p>
            </section>
          )}
          {showRelatedPrinciples && (
            <section class="card">
              <h2>Related principles</h2>
              <div class="tags">{data.principles.map((principle) => <Tag><ReferenceLink value={principle} kind="principle" /></Tag>)}</div>
            </section>
          )}
          {showRelatedTechniques && (
            <section class="card">
              <h2>Related techniques</h2>
              <ReferenceList items={related} kind="technique" />
            </section>
          )}
        </div>
      )}
      <article class="content-panel technique-content"><slot /><VisualSequence visuals={data.visuals} /></article>
    </div>
  </section>
</BaseLayout>
<style>
  .intro { max-width: 760px; font-size: 1.15rem; }
  .metadata-grid {
    align-items: stretch;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 15rem), 1fr));
    margin-top: 1.5rem;
  }
  .metadata-grid :global(.callout),
  .metadata-grid .card { height: 100%; }
  .metadata-grid h2 { font-size: 1.2rem; letter-spacing: -0.02em; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .technique-content { margin-top: 1.5rem; }
</style>
