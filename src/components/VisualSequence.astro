---
import { existsSync } from 'node:fs';
import { join, normalize, sep } from 'node:path';
import { withBase } from '@utils/paths';

interface VisualFrame {
  id: string;
  file: string;
  caption: string;
  alt?: string;
}

interface VisualGroup {
  title?: string;
  frames: VisualFrame[];
}

interface Visuals {
  base_path: string;
  frames?: VisualFrame[];
  groups?: VisualGroup[];
}

interface Props {
  visuals?: Visuals;
}

const { visuals } = Astro.props;
const supportedExtensions = new Set(['.png', '.jpg', '.jpeg']);
const publicRoot = join(process.cwd(), 'public');

function extensionFor(file: string) {
  const match = file.toLowerCase().match(/\.[^.\/]+$/);
  return match?.[0] ?? '';
}

function isSafePublicPath(path: string) {
  const normalized = normalize(path).replace(/^([/\\])+/, '');
  return normalized && !normalized.split(sep).includes('..');
}

function publicFileExists(basePath: string, file: string) {
  const relativePath = `${basePath.replace(/^\/+/, '').replace(/\/+$/, '')}/${file}`;
  if (!supportedExtensions.has(extensionFor(file)) || !isSafePublicPath(relativePath)) return false;
  const absolutePath = join(publicRoot, relativePath);
  return absolutePath.startsWith(publicRoot) && existsSync(absolutePath);
}

function imageHref(basePath: string, file: string) {
  return withBase(`${basePath.replace(/\/+$/, '')}/${file}`);
}

const groups: VisualGroup[] = visuals?.groups?.length
  ? visuals.groups
  : visuals?.frames?.length
    ? [{ frames: visuals.frames }]
    : [];
---
{visuals && groups.length > 0 && (
  <section class="visual-sequence" aria-labelledby="visual-reference-heading">
    <h2 id="visual-reference-heading">Visual reference</h2>
    <p class="visual-sequence__intro">
      Illustration slots are declared in the page metadata. Upload a matching PNG, JPG, or JPEG file to the documented folder to replace the placeholder automatically.
    </p>
    {groups.map((group) => (
      <section class="visual-sequence__group" aria-label={group.title ?? 'Visual sequence'}>
        {group.title && <h3>{group.title}</h3>}
        <div class="visual-sequence__grid">
          {group.frames.map((frame, index) => {
            const hasImage = publicFileExists(visuals.base_path, frame.file);
            const src = imageHref(visuals.base_path, frame.file);
            const alt = frame.alt ?? frame.caption;
            return (
              <figure class="visual-card">
                <figcaption class="visual-card__label"><span>Frame</span> {index + 1}</figcaption>
                <div class="visual-card__media">
                  {hasImage ? (
                    <img src={src} alt={alt} loading="lazy" decoding="async" />
                  ) : (
                    <div class="visual-card__placeholder" role="note" aria-label={`Illustration pending for ${frame.file}`}>
                      <div class="visual-card__placeholder-box" aria-hidden="true">
                        <span>Illustration pending</span>
                      </div>
                      <span class="visual-card__filename"><strong>Expected file:</strong>{' '}<span>{frame.file}</span></span>
                    </div>
                  )}
                </div>
                <p class="visual-card__caption">{frame.caption}</p>
              </figure>
            );
          })}
        </div>
      </section>
    ))}
  </section>
)}

<style>
  .visual-sequence {
    border-top: 1px solid var(--color-border);
    margin-top: 2rem;
    padding-top: 2rem;
  }

  .visual-sequence__intro {
    color: var(--color-muted);
    max-width: 48rem;
  }

  .visual-sequence__group + .visual-sequence__group {
    margin-top: 2rem;
  }

  .visual-sequence__grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 15rem), 1fr));
  }

  .visual-card {
    background: #fffdf8;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: 0 10px 24px rgba(23, 32, 51, 0.06);
    margin: 0;
    overflow: hidden;
  }

  .visual-card__label {
    align-items: baseline;
    color: var(--color-accent);
    display: flex;
    font-size: 1.15rem;
    font-weight: 800;
    gap: 0.35rem;
    letter-spacing: 0.02em;
    padding: 0.85rem 1rem 0;
  }

  .visual-card__label span {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .visual-card__media {
    aspect-ratio: 4 / 3;
    display: grid;
    margin: 0.75rem 1rem;
    overflow: hidden;
    place-items: center;
  }

  .visual-card__media img {
    border-radius: 12px;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .visual-card__placeholder {
    background: #fbfaf6;
    border: 1px dashed var(--color-border);
    border-radius: 12px;
    color: var(--color-muted);
    display: grid;
    gap: 0.8rem;
    height: 100%;
    padding: 0.85rem;
    text-align: center;
    width: 100%;
  }

  .visual-card__placeholder-box {
    align-items: center;
    background:
      linear-gradient(135deg, rgba(139, 47, 47, 0.1), rgba(244, 232, 226, 0.42)),
      #fffdf8;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    display: flex;
    justify-content: center;
    min-height: 7rem;
  }

  .visual-card__placeholder-box span {
    color: var(--color-text);
    font-weight: 800;
  }

  .visual-card__filename {
    align-items: center;
    display: grid;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
    gap: 0.2rem;
    overflow-wrap: anywhere;
  }

  .visual-card__filename strong {
    color: var(--color-accent);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .visual-card__caption {
    border-top: 1px solid var(--color-border);
    margin: 0;
    padding: 0.9rem 1rem 1rem;
  }
</style>
