---
import InlineReferenceList from './InlineReferenceList.astro';
interface Props { belt: { data: { title: string; objectives?: string[]; techniqueGroups?: string[]; techniques?: string[]; summary: string; } }; href: string; }
const { belt, href } = Astro.props;
const objectives = belt.data.objectives ?? [];
const groups = belt.data.techniqueGroups ?? belt.data.techniques ?? [];
---
<article class="card belt-card">
  <p class="eyebrow">Learning path</p>
  <h3>{belt.data.title}</h3>
  <p>{belt.data.summary}</p>
  <strong>Objectives</strong>
  <ul>{objectives.slice(0, 3).map((item) => <li>{item}</li>)}</ul>
  <strong>Main focus</strong>
  <p class="muted"><InlineReferenceList items={groups} kind="technique" limit={4} /></p>
  <a class="button secondary" href={href}>View level page</a>
</article>
<style>
  .belt-card { display: flex; flex-direction: column; gap: 0.45rem; }
  h3, p, ul { margin-top: 0; }
  .button { align-self: flex-start; margin-top: auto; }
</style>
