---
import Tag from './Tag.astro';
interface Props { technique: { data: { title: string; category: string; belt?: string; beltLevel?: string; attack?: string; attackType?: string; summary: string; principles: string[]; } }; href: string; }
const { technique, href } = Astro.props;
const data = technique.data;
---
<article class="card technique-card">
  <p class="eyebrow">{data.category.replace(/-/g, ' ')}</p>
  <h3><a href={href}>{data.title}</a></h3>
  <p>{data.summary}</p>
  <dl>
    <div><dt>Belt</dt><dd>{data.belt ?? data.beltLevel}</dd></div>
    <div><dt>Attack</dt><dd>{data.attack ?? data.attackType}</dd></div>
  </dl>
  <div class="tags">{data.principles.map((principle) => <Tag label={principle} />)}</div>
</article>
<style>
  .technique-card { display: grid; gap: 0.6rem; }
  h3, p { margin: 0; }
  h3 a { color: var(--color-text); text-decoration: none; }
  dl { display: grid; gap: 0.35rem; margin: 0; }
  div { min-width: 0; }
  dt { color: var(--color-muted); font-size: 0.78rem; font-weight: 800; text-transform: uppercase; }
  dd { margin: 0; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
</style>
