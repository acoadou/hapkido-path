---
interface Props { title?: string; items: string[]; }
const { title, items } = Astro.props;
---
<section class="checklist">
  {title && <h3>{title}</h3>}
  <ul>
    {items.map((item) => <li><span aria-hidden="true">□</span><span>{item}</span></li>)}
  </ul>
</section>
<style>
  .checklist { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1rem; }
  h3 { margin-top: 0; }
  ul { list-style: none; padding: 0; margin: 0; }
  li { display: flex; gap: 0.6rem; align-items: flex-start; }
  li + li { margin-top: 0.5rem; }
  span:first-child { color: var(--color-accent); font-weight: 900; }
</style>
