---
import { withBase } from '@utils/paths';
import { mainNavigation } from '../data/navigation';
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBase('/')}>The Hapkido Path</a>
    <nav aria-label="Main navigation">
      {mainNavigation.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
    </nav>
  </div>
</header>
<style>
  .site-header { border-bottom: 1px solid var(--color-border); background: rgba(248,247,242,0.92); position: sticky; top: 0; z-index: 10; backdrop-filter: blur(12px); }
  .header-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.85rem 0; }
  .brand { color: var(--color-text); font-weight: 900; letter-spacing: -0.03em; text-decoration: none; }
  nav { display: flex; flex-wrap: wrap; gap: 0.45rem 0.8rem; justify-content: flex-end; }
  nav a { color: var(--color-text); font-size: 0.93rem; font-weight: 750; text-decoration: none; }
  nav a:hover { color: var(--color-accent); }
  @media (max-width: 760px) { .header-inner { align-items: flex-start; flex-direction: column; } nav { justify-content: flex-start; } }
</style>
