---
interface Props { title: string; subtitle: string; primaryHref?: string; primaryLabel?: string; secondaryHref?: string; secondaryLabel?: string; }
const { title, subtitle, primaryHref, primaryLabel, secondaryHref, secondaryLabel } = Astro.props;
---
<section class="hero">
  <div class="container hero-inner">
    <p class="eyebrow">Guided study notes</p>
    <h1>{title}</h1>
    <p class="subtitle">{subtitle}</p>
    <div class="button-row">
      {primaryHref && <a class="button primary" href={primaryHref}>{primaryLabel}</a>}
      {secondaryHref && <a class="button secondary" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
  </div>
</section>
<style>
  .hero { padding: clamp(3rem, 10vw, 7rem) 0; background: radial-gradient(circle at top right, #f4e8e2 0, rgba(244,232,226,0) 42%); }
  .hero-inner { max-width: 820px; }
  .subtitle { color: var(--color-muted); font-size: clamp(1.15rem, 3vw, 1.55rem); max-width: 680px; }
</style>
